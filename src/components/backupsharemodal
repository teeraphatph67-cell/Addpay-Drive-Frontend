                              onClick={() => handleRemoveRecipient(r.id)}
                              className="p-1 text-gray-400 hover:text-red-500 transition-colors"
                            >
                              <FiX size={16} />
                            </button>
                          </div>
                        </div>
                      );
                    })}
                  </div>
                )}
              </div>
              {/* Existing Permissions */}
              {existingPermissions.length > 0 && (
                <div className="space-y-4">
                  {/* Floating Copy Button สำหรับลิงก์ที่มีอยู่ */}
                  {existingPermissions.some(
                    (p) => p.shared_link_token || p.link,
                  ) && (
                    <div className="relative">
                      <div className="absolute -top-3 right-0 z-10">
                        <button
                          onClick={() => {
                            const permWithLink = existingPermissions.find(
                              (p) => p.shared_link_token || p.link,
                            );
                            if (permWithLink) {
                              const frontendLink = getFrontendShareLink(
                                permWithLink.link,
                                permWithLink.shared_link_token,
                              );
                              copySpecificLink(
                                frontendLink,
                                "floating-copy-btn",
                              );
                            }
                          }}
                          className={`flex items-center gap-2 px-3 py-1.5 rounded-full shadow-sm transition-all ${
                            copiedLinks["floating-copy-btn"]
                              ? "bg-green-500 text-white shadow-green-200"
                              : "bg-white text-gray-700 border border-gray-300 hover:bg-gray-50 shadow-md"
                          }`}
                          title="คัดลอกลิงก์แชร์"
                        >
                          {copiedLinks["floating-copy-btn"] ? (
                            <>
                              <FiCheck size={14} />
                              <span className="text-xs font-medium">
                                คัดลอกแล้ว
                              </span>
