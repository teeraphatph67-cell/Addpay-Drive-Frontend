                            <img
                              src={r.avatar}
                              alt=""
                              className="w-8 h-8 rounded-full"
                            />
                            <div className="min-w-0 flex-1">
                              <div className="text-sm font-medium text-gray-900 truncate">
                                {r.email}
                              </div>
                            </div>
                          </div>

                          <div className="flex items-center gap-2">
                            <select
                              value={r.role}
                              onChange={(e) =>
                                handleChangeRole(r.id, e.target.value)
