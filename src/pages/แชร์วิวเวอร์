              <div className="bg-blue-50 border border-blue-100 rounded-lg p-3 mb-4">
                <div className="flex items-center justify-center gap-2 text-blue-700">
                  <FiMail size={16} />
                  <span className="font-medium">สำหรับ: {shareData.permission.shared_email}</span>
                </div>
              </div>
            )}

            <p className="text-gray-500 mb-6 text-sm">
              กรุณาล็อกอินด้วยบัญชีที่ถูกต้องเพื่อเข้าถึงเนื้อหา
            </p>

            <div className="space-y-3">
              <button
                onClick={handleLoginRedirect}
                className="w-full py-3 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 font-medium flex items-center justify-center gap-2 transition-colors"
              >
                <FiLogIn size={18} />
                <span>ล็อกอินเพื่อเข้าถึง</span>
              </button>

              <button
                onClick={() => navigate("/mydrive")}
                className="w-full py-3 bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 font-medium transition-colors"
              >
                กลับหน้าหลัก
              </button>
            </div>

            <div className="mt-6 pt-6 border-t border-gray-200">
              <p className="text-xs text-gray-500">
                หากคุณไม่สามารถเข้าถึงได้ โปรดติดต่อเจ้าของเนื้อหา
              </p>
            </div>
          </div>
        </div>
      </ShareLayout>
    );
  }

  if (error && !requiresLogin)
    return (
      <ShareLayout>
        <div className="flex items-center justify-center py-12">
          <div className="bg-white p-8 rounded-2xl shadow-sm border border-gray-200 text-center max-w-sm">
            <FiAlertCircle size={48} className="text-red-400 mx-auto mb-4" />
            <h2 className="text-xl font-bold text-gray-800 mb-2">
              เกิดข้อผิดพลาด
            </h2>
            <p className="text-gray-500 mb-6">{error}</p>
            <button
              onClick={() => navigate("/mydrive")}
              className="w-full py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700"
            >
              กลับหน้าหลัก
            </button>
          </div>
        </div>
      </ShareLayout>
    );

  if (!shareData) return null;

  return (
    <>
      <ShareLayout>
        <div
          className="space-y-6"
          onDragEnter={hasPermission('edit') ? handleDrag : undefined}
          onDragOver={hasPermission('edit') ? handleDrag : undefined}
          onDragLeave={hasPermission('edit') ? handleDrag : undefined}
          onDrop={hasPermission('edit') ? handleDrop : undefined}
        >
          {/* Share Info Header */}
          <div className="bg-white rounded-2xl border border-gray-200 p-5 shadow-sm">
            <div className="flex flex-col md:flex-row md:items-center justify-between gap-4">
              <div className="flex items-center gap-3">
                {shareData.type === 'folder' ? (
                  <TbFolderFilled className="text-yellow-400" size={28} />
                ) : (
                  getFileIcon(shareData.data)
                )}
                <div>
                  <h1 className="text-xl font-bold text-gray-800">
                    {shareData.type === 'folder'
                      ? `${currentFolder?.name || currentFolder?.folder_name || shareData.data.name || shareData.data.folder_name || "โฟลเดอร์"}`
                      : shareData.data.file_name
                    }
                  </h1>
                  <div className="flex items-center gap-2 mt-1">
                    <span className="text-xs px-2 py-1 bg-emerald-100 text-emerald-700 rounded-full">
                      {shareData.type === 'folder' ? 'โฟลเดอร์' : 'ไฟล์'}
                    </span>
                    {shareData.permission?.scope === "private" && (
                      <span className="text-xs px-2 py-1 bg-blue-100 text-blue-700 rounded-full flex items-center gap-1">
                        <FiLock size={10} /> ส่วนตัว
                      </span>
                    )}

                    {/* Permission Badge */}
                    {hasPermission('edit') && (
                      <span className="text-xs px-2 py-1 bg-green-100 text-green-700 rounded-full flex items-center gap-1">
                        <FiEdit size={10} /> แก้ไขได้
                      </span>
                    )}
                  </div>
                </div>
              </div>

              <div className="flex items-center gap-3">
                {shareData.type === 'folder' && hasPermission('edit') && (
                  <div className="flex items-center gap-2">
                    <button
                      onClick={() => fileInputRef.current?.click()}
                      className="px-3 py-1.5 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 flex items-center gap-2 text-sm font-medium transition-all"
                      disabled={uploading}
                    >
                      <FiUpload size={14} />
                      <span>อัพโหลด</span>
                    </button>
                    <button
                      onClick={() => setShowCreateFolderModal(true)}
                      className="px-3 py-1.5 bg-blue-600 text-white rounded-lg hover:bg-blue-700 flex items-center gap-2 text-sm font-medium transition-all"
                      disabled={creatingFolder}
                    >
                      <FiPlus size={14} />
                      <span>สร้างโฟลเดอร์</span>
                    </button>
                  </div>
                )}

                <button
                  onClick={copyLink}
                  className={`px-4 py-2 rounded-lg flex items-center gap-2 text-sm font-medium transition-all ${copied
                    ? "bg-emerald-100 text-emerald-700"
                    : "bg-white border border-gray-300 text-gray-700 hover:border-emerald-300"
                    }`}
                >
                  {copied ? (
                    <>
                      <FiCheck size={16} /> คัดลอกแล้ว!
                    </>
                  ) : (
                    <>
                      <FiCopy size={16} /> คัดลอกลิงก์
                    </>
                  )}
                </button>
              </div>
            </div>

            {shareData.permission?.scope === "private" && (
              <div className={`mt-4 rounded-lg p-3 border ${isLinkExpired()
                ? "bg-red-50 border-red-200"
                : "bg-blue-50 border-blue-200"
                }`}>
                <div className="flex items-start gap-3">
                  <div className={`p-2 rounded-lg ${isLinkExpired() ? "bg-red-100" : "bg-blue-100"
                    }`}>
                    {isLinkExpired() ? (
                      <FiAlertTriangle className="text-red-600" size={20} />
                    ) : (
                      <FiLock className="text-blue-600" size={20} />
                    )}
                  </div>
                  <div className="flex-1">
                    <h4 className={`font-medium mb-1 ${isLinkExpired() ? "text-red-800" : "text-blue-800"
                      }`}>
                      {isLinkExpired() ? "ลิงก์หมดอายุแล้ว" : "ลิงก์ส่วนตัว"}
                    </h4>
                    <p className={`text-sm mb-2 ${isLinkExpired() ? "text-red-700" : "text-blue-700"
                      }`}>
                      {isLinkExpired()
                        ? "ลิงก์นี้หมดอายุแล้ว คุณไม่สามารถเข้าถึงไฟล์ได้"
                        : shareData.permission.shared_email
                          ? `ไฟล์นี้ถูกแชร์ให้คุณเป็นการส่วนตัว`
                          : "ไฟล์นี้ถูกแชร์ให้คุณเป็นการส่วนตัว"
                      }
                    </p>
                    {shareData.permission?.expires_at && (
                      <div className={`text-xs px-2 py-1 rounded inline-flex items-center gap-1 ${isLinkExpired() ? "bg-red-100 text-red-700" : "bg-blue-100 text-blue-700"
                        }`}>
                        <FiClock size={12} />
                        <span>
                          {isLinkExpired() ? "หมดอายุเมื่อ: " : "หมดอายุ: "}
                          {new Date(shareData.permission.expires_at).toLocaleDateString('th-TH')}
                          {new Date(shareData.permission.expires_at).toLocaleTimeString('th-TH', {
                            hour: '2-digit',
                            minute: '2-digit'
                          })}
                        </span>
                      </div>
                    )}
                  </div>
                </div>
              </div>
            )}
          </div>

          <div className="grid grid-cols-1 lg:grid-cols-4 gap-6">
            <div className="lg:col-span-3">
              {shareData.type === 'folder' ? (
                <div className="bg-white rounded-2xl border border-gray-200 p-5 shadow-sm">
                  {renderFolderContent(currentFolder)}
                </div>
              ) : (
                renderFilePreview(shareData.data)
              )}
            </div>

            <div className="lg:col-span-1 space-y-4">
              <div className="bg-white rounded-2xl border border-gray-200 p-5 shadow-sm">
                <h3 className="text-sm font-semibold text-emerald-900 uppercase tracking-wider mb-4">
                  ข้อมูลการแชร์
                </h3>
                <div className="space-y-4">
                  <div className="flex items-start gap-3 text-sm">
                    <FiInfo className="mt-1 text-emerald-500" />
                    <div>
                      <p className="text-gray-400 text-xs">ประเภท</p>
                      <p className="text-gray-700 font-medium">
                        {shareData.type === 'folder' ? 'โฟลเดอร์' : 'ไฟล์'}
                      </p>
                    </div>
                  </div>

                  <div className="flex items-start gap-3 text-sm">
                    <FiUser className="mt-1 text-emerald-500" />
                    <div>
                      <p className="text-gray-400 text-xs">เจ้าของ</p>
                      <p className="text-gray-700 font-medium">
                        {shareData.owner_name}
                      </p>
                    </div>
                  </div>

                  <div className="flex items-start gap-3 text-sm">
                    {shareData.permission?.scope === "public" ? (
                      <FiGlobe className="mt-1 text-emerald-500" />
                    ) : (
                      <FiLock className="mt-1 text-blue-500" />
                    )}
                    <div>
                      <p className="text-gray-400 text-xs">การเข้าถึง</p>
                      <p className={`font-medium flex items-center gap-1 ${shareData.permission?.scope === "public"
                        ? "text-emerald-600"
                        : "text-blue-600"
                        }`}>
                        {shareData.permission?.scope === "public" ? (
                          <>
                            <FiUnlock size={12} /> สาธารณะ
                          </>
                        ) : (
                          <>
                            <FiLock size={12} /> ส่วนตัว
                          </>
                        )}
                      </p>
                    </div>
                  </div>

                  {shareData.permission?.scope === "private" && shareData.permission.shared_email && (
                    <div className="flex items-start gap-3 text-sm">
                      <FiMail className="mt-1 text-blue-500" />
                      <div>
                        <p className="text-gray-400 text-xs">แชร์ให้กับ</p>
                        <p className="text-blue-700 font-medium">
                          {shareData.permission.shared_email}
                        </p>
                      </div>
                    </div>
                  )}

                  {shareData.permission?.expires_at && (
                    <div className="flex items-start gap-3 text-sm">
                      <FiClock className={`mt-1 ${isLinkExpired() ? "text-red-500" : "text-emerald-500"
                        }`} />
                      <div>
                        <p className="text-gray-400 text-xs">หมดอายุ</p>
                        <p className={`font-medium ${isLinkExpired() ? "text-red-600" : "text-emerald-700"
                          }`}>
                          {new Date(shareData.permission.expires_at).toLocaleDateString('th-TH')}
                          <span className="block text-xs font-normal text-gray-500">
                            {new Date(shareData.permission.expires_at).toLocaleTimeString('th-TH', {
                              hour: '2-digit',
                              minute: '2-digit'
                            })}
                          </span>
                        </p>
                      </div>
                    </div>
                  )}

                  <div className="pt-3 border-t border-gray-100">
                    <p className="text-xs text-gray-400 mb-2">สิทธิ์การเข้าถึง:</p>
                    <div className="space-y-2">
                      <div className="flex items-center justify-between">
                        <span className="text-sm text-gray-600">ดูข้อมูล</span>
                        <span className={`text-xs px-2 py-1 rounded ${hasPermission('view') && !isLinkExpired()
                          ? 'bg-emerald-100 text-emerald-700'
                          : 'bg-gray-100 text-gray-500'
                          }`}>
                          {hasPermission('view') && !isLinkExpired() ? 'อนุญาต' : 'ไม่อนุญาต'}
                        </span>
                      </div>
                      <div className="flex items-center justify-between">
                        <span className="text-sm text-gray-600">แก้ไข</span>
                        <span className={`text-xs px-2 py-1 rounded ${hasPermission('edit') && !isLinkExpired()
                          ? 'bg-emerald-100 text-emerald-700'
                          : 'bg-gray-100 text-gray-500'
                          }`}>
                          {hasPermission('edit') && !isLinkExpired() ? 'อนุญาต' : 'ไม่อนุญาต'}
                        </span>
                      </div>
                      <div className="flex items-center justify-between">
                        <span className="text-sm text-gray-600">ดาวน์โหลด</span>
                        <span className={`text-xs px-2 py-1 rounded ${hasPermission('download') && !isLinkExpired()
                          ? 'bg-emerald-100 text-emerald-700'
                          : 'bg-gray-100 text-gray-500'
                          }`}>
                          {hasPermission('download') && !isLinkExpired() ? 'อนุญาต' : 'ไม่อนุญาต'}
                        </span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              {shareData.type === 'folder' && currentFolder && (
                <div className="bg-white rounded-2xl border border-gray-200 p-5 shadow-sm">
                  <h3 className="text-sm font-semibold text-emerald-900 uppercase tracking-wider mb-4">
                    สถิติโฟลเดอร์
                  </h3>
                  <div className="space-y-3">
                    <div className="flex items-center justify-between">
                      <span className="text-sm text-gray-600">ไฟล์ทั้งหมด</span>
                      <span className="font-medium text-emerald-700">
                        {(currentFolder.files || []).length}
                      </span>
                    </div>
                    <div className="flex items-center justify-between">
                      <span className="text-sm text-gray-600">โฟลเดอร์ย่อย</span>
                      <span className="font-medium text-emerald-700">
                        {(currentFolder.subfolders || []).length}
                      </span>
                    </div>
                    <div className="flex items-center justify-between">
                      <span className="text-sm text-gray-600">สร้างเมื่อ</span>
                      <span className="text-sm text-gray-500">
                        {new Date(currentFolder.created_at).toLocaleDateString('th-TH')}
                      </span>
                    </div>
                  </div>
                </div>
              )}
            </div>
          </div>
        </div>
      </ShareLayout>

      {/* Upload Progress */}
      <UploadProgress
        progress={uploadProgress}
        onCancel={cancelUpload}
      />

      {/* Create Folder Modal */}
      <CreateFolderModal
        isOpen={showCreateFolderModal}
        onClose={() => {
          setShowCreateFolderModal(false);
          setFolderName("");
        }}
        onCreate={handleCreateFolder}
        folderName={folderName}
        setFolderName={setFolderName}
        isFetchingShare={creatingFolder}
      />
    </>
  );
}