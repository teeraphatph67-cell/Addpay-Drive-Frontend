// Upload Progress Component
const UploadProgress = ({ progress, onCancel }) => {
  if (Object.keys(progress).length === 0) return null;

  return (
    <div className="fixed bottom-4 right-4 z-50 max-w-sm w-full">
      {Object.entries(progress).map(([fileName, data]) => (
        <div
          key={fileName}
          className="bg-white rounded-xl shadow-lg border border-gray-200 p-3 mb-2"
        >
          <div className="flex items-center justify-between mb-1">
            <span className="text-sm font-medium truncate max-w-[200px]">
              {fileName}
            </span>
            <button
              onClick={() => onCancel(fileName)}
              className="text-gray-400 hover:text-red-500 text-xs"
            >
              ยกเลิก
            </button>
          </div>
          <div className="w-full bg-gray-200 rounded-full h-2">
            <div
              className="bg-emerald-500 h-2 rounded-full transition-all duration-300"
              style={{ width: `${data.percent || 0}%` }}
            />
          </div>
          <div className="text-xs text-gray-500 mt-1 text-right">
            {data.percent || 0}%
          </div>
        </div>
      ))}
    </div>
  );
};

// Create Folder Modal Component
const CreateFolderModal = ({ isOpen, onClose, onCreate, folderName, setFolderName, isFetchingShare }) => {
  if (!isOpen) return null;

  return (
    <div className="fixed inset-0 bg-black/40 flex items-center justify-center z-[99999]">
      <div className="bg-white rounded-xl p-6 w-[360px] shadow-xl">
        <h3 className="text-lg font-semibold mb-4">
          สร้างโฟลเดอร์ใหม่
        </h3>

        <input
          type="text"
          value={folderName}
          onChange={(e) => setFolderName(e.target.value)}
          placeholder="ชื่อโฟลเดอร์"
          className="w-full border rounded-lg px-3 py-2 mb-4 focus:outline-none focus:ring-2 focus:ring-emerald-500"
          autoFocus
          onKeyPress={(e) => {
            if (e.key === 'Enter') {
              onCreate();
            }
          }}
        />

        <div className="flex justify-end gap-2">
          <button
            className="px-4 py-2 rounded-lg text-gray-600 hover:bg-gray-100"
            onClick={onClose}
            disabled={isFetchingShare}
          >
            ยกเลิก
          </button>

          <button
            className="px-4 py-2 rounded-lg bg-emerald-600 text-white hover:bg-emerald-700 disabled:opacity-50 disabled:cursor-not-allowed"
            onClick={onCreate}
            disabled={!folderName.trim() || isFetchingShare}
          >
            {isFetchingShare ? "กำลังสร้าง..." : "สร้าง"}
          </button>
        </div>
      </div>
    </div>
  );
};

export default function ShareViewer() {
  const { shareToken } = useParams();
  const navigate = useNavigate();
  const location = useLocation();

  const [isFetchingShare, setIsFetchingShare] = useState(false);
  const [isUploading, setIsUploading] = useState(false);
  const [shareData, setShareData] = useState(null);
  const [error, setError] = useState(null);
  const [copied, setCopied] = useState(false);
  const [currentFolder, setCurrentFolder] = useState(null);
  const [breadcrumbs, setBreadcrumbs] = useState([]);
  const [requiresLogin, setRequiresLogin] = useState(false);
  const [folderLoading, setFolderLoading] = useState(false);

  // State สำหรับการจัดการไฟล์และโฟลเดอร์
  const [showCreateFolderModal, setShowCreateFolderModal] = useState(false);
  const [uploading, setUploading] = useState(false);
  const [creatingFolder, setCreatingFolder] = useState(false);
  const [folderName, setFolderName] = useState("");
  const [uploadProgress, setUploadProgress] = useState({});
  const [uploadError, setUploadError] = useState("");
  const [dragActive, setDragActive] = useState(false);

  // Refs
  const xhrMapRef = useRef({});
  const fileInputRef = useRef(null);

  // ฟังก์ชันเช็คสถานะล็อกอิน
  const isLoggedIn = () => {
    const token = localStorage.getItem("api_token");
    const user = localStorage.getItem("user");
    return !!(token && user);
  };

  useEffect(() => {
    if (shareToken) {
      fetchSharedData();
    }
  }, [shareToken]);

  useEffect(() => {
    const fromLogin = location.state?.fromLogin;
    const storedToken = localStorage.getItem('share_redirect_token');

    if (fromLogin && storedToken === shareToken) {
      console.log("Returned from login, refreshing data...");
      localStorage.removeItem('share_redirect_token');
      localStorage.removeItem('share_redirect_path');

      // รีเฟรชข้อมูล
      fetchSharedData();
    }
  }, [location, shareToken]);

  const fetchSharedData = async () => {
    try {
      setIsFetchingShare(true);        // ✅ ใช้ตัวนี้แทน setLoading
      setRequiresLogin(false);
      setError(null);

      const token = localStorage.getItem("api_token");
      const userEmail = localStorage.getItem("user_email");

      const headers = {
        "Content-Type": "application/json",
      };

      if (token) {
        headers["Authorization"] = `Bearer ${token}`;
      }

      const res = await fetch(`${API_BASE}/share/${shareToken}`, {
        method: "GET",
        headers,
      });

      const result = await res.json();

      if (!result.success) {
        if (
          res.status === 401 ||
          result.message?.toLowerCase().includes("login") ||
          result.message?.toLowerCase().includes("authenticate") ||
          result.message?.toLowerCase().includes("unauthorized")
        ) {
          if (!token) {
            localStorage.setItem("share_redirect_token", shareToken);
            localStorage.setItem("share_redirect_path", window.location.pathname);
            setRequiresLogin(true);
            setError("กรุณาล็อกอินเพื่อเข้าถึงไฟล์นี้");
            return;
          }
          throw new Error("คุณไม่มีสิทธิ์เข้าถึงไฟล์นี้");
        }

        throw new Error(result.message || "ไม่สามารถโหลดข้อมูลได้");
      }

      // 🔐 permission
      if (result.permission?.scope === "private") {
        const sharedEmail = result.permission.shared_email;

        if (!sharedEmail && !token) {
          setRequiresLogin(true);
          setError("ไฟล์นี้ต้องการการล็อกอิน");
          return;
        }

        if (
          sharedEmail &&
          (!token || userEmail?.toLowerCase() !== sharedEmail.toLowerCase())
        ) {
          setError("คุณไม่ได้รับอนุญาตให้เข้าถึงไฟล์นี้");
          return;
        }
      }

      // 👤 owner
      let ownerName =
        result.data?.owner_name ||
        result.data?.owner?.name ||
        "Anonymous";

      const shareInfo = {
        type: result.type,
        permission: result.permission,
        owner_name: ownerName,
        data: result.data,
      };

      setShareData(shareInfo);

      if (result.type === "folder") {
        const folderData = processFolderData(result.data);
        setCurrentFolder(folderData);
        setBreadcrumbs([
          {
            id: folderData.id,
            name: folderData.name || "โฟลเดอร์",
            data: folderData,
          },
        ]);
      }

    } catch (err) {
      console.error(err);
      setError(err.message || "ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้");
    } finally {
      setIsFetchingShare(false);       // ✅ ไม่กระทบ upload
    }
  };


  // ฟังก์ชันปรับโครงสร้างข้อมูลโฟลเดอร์ให้สอดคล้อง
  const processFolderData = (folder) => {
    if (!folder) return folder;

    // สร้างสำเนาของข้อมูล
    const processed = { ...folder };

    // กรอง items ออกเป็นไฟล์และโฟลเดอร์
    if (processed.items && Array.isArray(processed.items)) {
      processed.files = processed.items
        .filter(item => item.type === 'file')
        .map(item => ({
          ...item.data,

          // ✅ สำคัญมาก
          permission_id: item.permission_id,
          permissions: item.permissions,

          file_name: item.data.name,
          file_path: `/storage/${item.data.id}`,
          file_ext: item.data.name?.split('.').pop()?.toLowerCase(),
        }));

      processed.subfolders = processed.items
        .filter(item => item.type === 'folder')
        .map(item => ({
          ...item.data,

          // (เผื่ออนาคต)
          permission_id: item.permission_id,
          permissions: item.permissions,

          folder_name: item.data.name,
        }));
    }

    return processed;
  };

  // ฟังก์ชันอัพโหลดไฟล์
  const handleUploadFiles = async (files) => {
    if (!hasPermission("edit")) {
      setUploadError("คุณไม่มีสิทธิ์อัพโหลดไฟล์");
      return;
    }

    const token = localStorage.getItem("api_token");
    if (!token) {
      setUploadError("กรุณาล็อกอินก่อนอัพโหลดไฟล์");
      return;
    }

    const currentFolderId = currentFolder?.id || shareData?.data?.id;
    setUploading(true);

    const CHUNK_SIZE = 1024 * 1024 * 2; // 2MB

    for (const file of files) {
      try {
        // --------------------
        // 1️⃣ START UPLOAD
        // --------------------
        const startFd = new FormData();
        startFd.append("original_name", file.name);
        startFd.append("total_size", file.size);
        startFd.append("folder_id", currentFolderId || "");

        const startRes = await fetch(`${API_BASE}/upload/start`, {
          method: "POST",
          headers: {
            Authorization: `Bearer ${token}`,
          },
          body: startFd,
        });

        const startResult = await startRes.json();
        if (!startResult.upload_id) {
          throw new Error(startResult.message || "เริ่มอัพโหลดไม่สำเร็จ");
        }

        const uploadId = startResult.upload_id;
        const fileKey = `${file.name}_${uploadId}`;

        // init progress
        setUploadProgress((p) => ({
          ...p,
          [fileKey]: { percent: 100, uploadId, done: true },
        }));

        // 🔥 ลบ progress ออกหลังเสร็จ
        setTimeout(() => {
          setUploadProgress((p) => {
            const copy = { ...p };
            delete copy[fileKey];
            return copy;
          });
        }, 1500);


        // --------------------
        // 2️⃣ UPLOAD CHUNKS
        // --------------------
        let offset = 0;

        while (offset < file.size) {
          const chunk = file.slice(offset, offset + CHUNK_SIZE);
          const currentOffset = offset;

          offset = await new Promise((resolve, reject) => {
            const xhr = new XMLHttpRequest();

            xhr.open("POST", `${API_BASE}/upload/chunk`);
            xhr.setRequestHeader("Authorization", `Bearer ${token}`);

            // ✅ progress ของ chunk นี้
            xhr.upload.onprogress = (e) => {
              if (!e.lengthComputable) return;

              const uploaded = currentOffset + e.loaded;
              const percent = Math.min(
                100,
                Math.round((uploaded / file.size) * 100)
              );

              setUploadProgress((p) => ({
                ...p,
                [fileKey]: { percent, uploadId },
              }));
            };

            xhr.onload = () => {
              if (xhr.status >= 200 && xhr.status < 300) {
                const res = JSON.parse(xhr.responseText);

                // ✅ backend เป็นคนกำหนด offset
                resolve(res.uploaded_size);
              } else {
                reject(xhr.responseText);
              }
            };

            xhr.onerror = () => reject("network error");

            const fd = new FormData();
            fd.append("upload_id", uploadId);
            fd.append("chunk", chunk);
            fd.append("offset", currentOffset);

            xhr.send(fd);
          });
        }



        // --------------------
        // 3️⃣ FINISH
        // --------------------
        const finishFd = new FormData();
        finishFd.append("upload_id", uploadId);

        const finishRes = await fetch(`${API_BASE}/upload/finish`, {
          method: "POST",
          headers: {
            Authorization: `Bearer ${token}`,
          },
          body: finishFd,
        });

        if (!finishRes.ok) {
          const text = await finishRes.text();
          throw new Error(text);
        }

        setUploadProgress((p) => ({
          ...p,
          [fileKey]: { percent: 100, uploadId },
        }));

      } catch (err) {
        console.error(err);
        setUploadError(err.message || "อัพโหลดไฟล์ล้มเหลว");
      }
    }

    // 🔥 ทุกไฟล์เสร็จแล้ว ค่อย refresh ครั้งเดียว
    setUploading(false);
    setIsUploading(false);  // ✅ ตั้ง isUploading เป็น false ก่อน refetch
    await fetchSharedData();  // ✅ รอ fetch เสร็จก่อนดำเนินการต่อ
  };



  // ฟังก์ชันยกเลิกอัพโหลด
  const cancelUpload = async (fileName) => {
    const data = uploadProgress[fileName];
    if (!data?.uploadId) return;

    // abort xhr
    const xhr = xhrMapRef.current[fileName];
    if (xhr) xhr.abort();

    // แจ้ง backend
    const fd = new FormData();
    fd.append("upload_id", data.uploadId);

    await fetch(`${API_BASE}/upload/cancel`, {
      method: "POST",
      headers: {
        Authorization: `Bearer ${localStorage.getItem("api_token")}`,
      },
      body: fd,
    });

    setUploadProgress((p) => {
      const copy = { ...p };
      delete copy[fileName];
      return copy;
    });
  };

  useEffect(() => {
    if (!requiresLogin) return;

    const token = localStorage.getItem("api_token");
    if (!token) return;

    console.log("🔁 logged in, refetch share");
    fetchSharedData();
  }, [requiresLogin]);


  // ฟังก์ชันสร้างโฟลเดอร์
  const handleCreateFolder = async () => {
    // 1. ตรวจสอบความพร้อมของข้อมูล
    if (!folderName.trim()) {
      setUploadError("กรุณากรอกชื่อโฟลเดอร์");
      return;
    }

    const token = localStorage.getItem("api_token");
    if (!token) {
      setUploadError("กรุณาล็อกอินก่อนสร้างโฟลเดอร์");
      return;
    }

    setCreatingFolder(true);
    setUploadError("");

    try {
      // ดึง ID โฟลเดอร์ปัจจุบัน เพื่อใช้เป็น parent_id
      const currentFolderId = currentFolder?.id || shareData?.data?.id;

      // ดึง drive_id จาก shareData (ถ้าไม่มีให้ใช้ default เป็น 9 ตามที่คุณเทสผ่าน)
      const driveId = shareData?.data?.drive_id || 9;

      // 2. เรียก API ไปที่ /AddFolder (ไม่ใช่ /folders/create)
      const response = await fetch(`${API_BASE}/AddFolder`, {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "Authorization": `Bearer ${token}`,
          "Accept": "application/json" // แนะนำให้ใส่ไว้เพื่อให้ Server ตอบกลับเป็น JSON เสมอ
        },
        body: JSON.stringify({
          name: folderName,
          parent_id: currentFolderId || null,
          drive_id: driveId
        }),
      });

      // 3. ตรวจสอบ Status Code ก่อน parse JSON
      if (response.status === 405) {
        throw new Error("Method Not Allowed: โปรดตรวจสอบว่า API Base URL ถูกต้องหรือไม่");
      }

      const result = await response.json();

      if (result.success) {
        setFolderName(""); // ล้างค่าใน Input
        setShowCreateFolderModal(false); // ปิด Modal

        // แจ้งเตือนสำเร็จ (ถ้ามีฟังก์ชัน showPopup)
        if (typeof showPopup === 'function') {
          showPopup(`สร้างโฟลเดอร์ "${folderName}" สำเร็จ`);
        }

        // 4. รีเฟรชข้อมูลหน้าจอ
        setIsFetchingShare(true);  // ✅ เพิ่ม loading state
        await fetchSharedData();
      } else {
        setUploadError(result.message || "สร้างโฟลเดอร์ล้มเหลว");
      }
    } catch (err) {
      console.error("Create Folder Error:", err);
      setUploadError(err.message || "ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้");
    } finally {
      setCreatingFolder(false);
    }
  };

  // ฟังก์ชันจัดการ Drag & Drop
  const handleDrag = (e) => {
    e.preventDefault();
    e.stopPropagation();
    if (["dragenter", "dragover"].includes(e.type)) {
      setDragActive(true);
    } else if (e.type === "dragleave") {
      setDragActive(false);
    }
  };

  const handleDrop = (e) => {
    e.preventDefault();
    e.stopPropagation();
    setDragActive(false);

    if (e.dataTransfer.files.length > 0 && hasPermission('edit')) {
      handleUploadFiles(e.dataTransfer.files);
      e.dataTransfer.clearData();
    }
  };

  const handleFileSelect = (e) => {
    if (e.target.files.length > 0 && hasPermission('edit')) {
      handleUploadFiles(e.target.files);
      e.target.value = null; // รีเซ็ต input
    }
  };

  const handleLoginRedirect = () => {
    localStorage.setItem('share_redirect_token', shareToken);
    localStorage.setItem('share_redirect_path', window.location.pathname);
    navigate('/login', {
      state: {
        fromShare: true,
        shareToken: shareToken
      }
    });
  };

  const copyLink = () => {
    navigator.clipboard.writeText(window.location.href);
    setCopied(true);
    setTimeout(() => setCopied(false), 2000);
  };

  const getFileIcon = (item) => {
    if (item.mime_type?.startsWith("image/"))
      return <FiImage className="text-emerald-600" size={20} />;
    if (item.mime_type?.startsWith("video/"))
      return <FiVideo className="text-emerald-600" size={20} />;
    if (item.mime_type?.startsWith("audio/"))
      return <FiMusic className="text-emerald-600" size={20} />;
    if (item.mime_type?.includes("pdf"))
      return <FiFileText className="text-emerald-600" size={20} />;
    if (["zip", "rar", "7z"].includes(item.file_ext?.toLowerCase()))
      return <FiArchive className="text-emerald-600" size={20} />;
    return <FiFile className="text-emerald-600" size={20} />;
  };

  const formatFileSize = (sizeMB) => {
    if (!sizeMB && sizeMB !== 0) return "Unknown";
    if (sizeMB < 1) return `${(sizeMB * 1024).toFixed(0)} KB`;
    return `${sizeMB.toFixed(2)} MB`;
  };

  const hasPermission = (action, item = null) => {
    const perm = item
      ? getItemPermission(item)
      : shareData?.permission;

    if (!perm) return false;

    switch (action) {
      case "view":
        return perm.allow_view === true || perm.allow_view === 1;
      case "edit":
        return perm.allow_edit === true || perm.allow_edit === 1;
      case "download":
        return perm.allow_download === true || perm.allow_download === 1;
      default:
        return false;
    }
  };

  const isLinkExpired = () => {
    if (!shareData?.permission?.expires_at) return false;
    return new Date(shareData.permission.expires_at) < new Date();
  };

  const handleFileClick = (file) => {
    if (shareData.permission?.scope === "private") {
      if (!hasPermission('view')) {
        alert("คุณไม่มีสิทธิ์เข้าถึงไฟล์นี้");
        return;
      }

      if (isLinkExpired()) {
        alert("ลิงก์นี้หมดอายุแล้ว");
        return;
      }
    }

    const fileUrl = `${BASE_URL}${file.file_path}`;

    if (file.mime_type?.startsWith("image/")) {
      window.open(fileUrl, '_blank');
    } else if (file.mime_type?.includes("pdf") ||
      file.mime_type?.startsWith("video/") ||
      file.mime_type?.startsWith("audio/")) {
      window.open(fileUrl, '_blank');
    } else {
      if (!hasPermission('download')) {
        alert("คุณไม่มีสิทธิ์ดาวน์โหลดไฟล์นี้");
        return;
      }

      const a = document.createElement('a');
      a.href = fileUrl;
      a.download = file.file_name;
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
    }
  };

  const fetchFolderContent = async (folderId) => {
    try {
      setFolderLoading(true);

      const token = localStorage.getItem("api_token");
      const headers = {
        "Content-Type": "application/json",
      };

      if (token) {
        headers["Authorization"] = `Bearer ${token}`;
      }

      console.log(`Fetching folder ${folderId} content...`);

      // ลองใช้ endpoint สำหรับดึงข้อมูลโฟลเดอร์ย่อย
      const res = await fetch(`${API_BASE}/share/${shareToken}/folder/${folderId}`, {
        method: "GET",
        headers: headers,
      });

      if (res.ok) {
        const result = await res.json();
        console.log("Folder content API response:", result);

        if (result.success) {
          return processFolderData(result.data);
        }
      }

      // ถ้าไม่มี endpoint พิเศษ หรือผิดพลาด ให้คืนค่าเดิม
      return null;
    } catch (err) {
      console.error("Error fetching folder content:", err);
      return null;
    } finally {
      setFolderLoading(false);
    }
  };

  // ✅ รีเฟรชเฉพาะโฟลเดอร์ปัจจุบันโดยไม่ต้องกลับไปหน้าแรก
  const refreshCurrentFolder = async () => {
    if (!currentFolder?.id || !shareToken) return;

    try {
      const token = localStorage.getItem("api_token");
      const headers = {
        "Content-Type": "application/json",
      };

      if (token) {
        headers["Authorization"] = `Bearer ${token}`;
      }

      const res = await fetch(`${API_BASE}/share/${shareToken}/folder/${currentFolder.id}`, {
        method: "GET",
        headers: headers,
      });

      if (res.ok) {
        const result = await res.json();
        if (result.success) {
          const updatedFolder = processFolderData(result.data);
          setCurrentFolder(updatedFolder);

          // อัพเดต breadcrumb เฉพาะตำแหน่งปัจจุบัน
          setBreadcrumbs(prev =>
            prev.map((crumb, index) =>
              index === prev.length - 1
                ? { ...crumb, data: updatedFolder }
                : crumb
            )
          );
        }
      }
    } catch (err) {
      console.error("Error refreshing current folder:", err);
    }
  };

  const handleFolderClick = async (folder) => {
    if (shareData.permission?.scope === "private") {
      if (!hasPermission('view')) {
        alert("คุณไม่มีสิทธิ์เข้าถึงโฟลเดอร์นี้");
        return;
      }

      if (isLinkExpired()) {
        alert("ลิงก์นี้หมดอายุแล้ว");
        return;
      }
    }

    try {
      // ตรวจสอบว่ามีข้อมูล items อยู่แล้วหรือไม่
      if (folder.items && Array.isArray(folder.items)) {
        // มีข้อมูลอยู่แล้ว ไม่ต้องดึงใหม่
        const processedFolder = processFolderData(folder);
        const newBreadcrumbs = [...breadcrumbs, {
          id: processedFolder.id,
          name: processedFolder.name || processedFolder.folder_name,
          data: processedFolder
        }];
        setBreadcrumbs(newBreadcrumbs);
        setCurrentFolder(processedFolder);
      } else {
        // ยังไม่มีข้อมูล ลองดึงจาก API
        const folderContent = await fetchFolderContent(folder.id);

        if (folderContent) {
          // ได้ข้อมูลใหม่จาก API
          const newBreadcrumbs = [...breadcrumbs, {
            id: folderContent.id,
            name: folderContent.name || folderContent.folder_name,
            data: folderContent
          }];
          setBreadcrumbs(newBreadcrumbs);
          setCurrentFolder(folderContent);
        } else {
          // ไม่สามารถดึงข้อมูลได้ แต่ยังสามารถเข้าโฟลเดอร์ได้
          const processedFolder = processFolderData(folder);
          const newBreadcrumbs = [...breadcrumbs, {
            id: processedFolder.id,
            name: processedFolder.name || processedFolder.folder_name,
            data: processedFolder
          }];
          setBreadcrumbs(newBreadcrumbs);
          setCurrentFolder(processedFolder);

          console.log("Using existing folder data, no additional content available");
        }
      }
    } catch (err) {
      console.error("Error handling folder click:", err);
      alert("ไม่สามารถเข้าถึงโฟลเดอร์ได้: " + err.message);
    }
  };

  const handleBreadcrumbClick = async (index) => {
    if (index === breadcrumbs.length - 1) return; // คลิกที่ตำแหน่งปัจจุบัน

    const breadcrumb = breadcrumbs[index];

    // ถ้าเป็น root folder (index = 0)
    if (index === 0) {
      setBreadcrumbs([breadcrumb]);
      setCurrentFolder(breadcrumb.data);
      return;
    }

    // ลองดึงข้อมูลโฟลเดอร์ใหม่ถ้าจำเป็น
    const newFolderData = await fetchFolderContent(breadcrumb.id);

    if (newFolderData) {
      const updatedBreadcrumb = {
        ...breadcrumb,
        data: newFolderData
      };

      const newBreadcrumbs = breadcrumbs.slice(0, index + 1).map((bc, i) =>
        i === index ? updatedBreadcrumb : bc
      );

      setBreadcrumbs(newBreadcrumbs);
      setCurrentFolder(newFolderData);
    } else {
      // ใช้ข้อมูลเดิม
      const newBreadcrumbs = breadcrumbs.slice(0, index + 1);
      setBreadcrumbs(newBreadcrumbs);
      setCurrentFolder(breadcrumb.data);
    }
  };

  const handleGoBack = () => {
    if (breadcrumbs.length > 1) {
      const newBreadcrumbs = breadcrumbs.slice(0, -1);
      setBreadcrumbs(newBreadcrumbs);
      setCurrentFolder(newBreadcrumbs[newBreadcrumbs.length - 1].data);
    }
  };

  const getItemPermission = (item) => {
    return item.permissions || shareData?.permission || null;
  };

  const handleDownload = async (item) => {
    const pId = item.permission_id || item.id || shareData?.permission?.id;

    if (!pId) {
      alert("ไม่พบ ID สำหรับดาวน์โหลด");
      return;
    }

    try {
      const token = localStorage.getItem("api_token");

      const downloadUrl = `${API_BASE}/shared/file/${pId}/download`;
      console.log("Downloading from:", downloadUrl);

      const res = await fetch(downloadUrl, {
        method: "GET",
        headers: {
          "Authorization": `Bearer ${token}`,
          "Accept": "application/json",
        },
      });

      if (res.status === 404) {
        throw new Error("ไม่พบไฟล์ที่ต้องการดาวน์โหลด (404) กรุณาตรวจสอบ ID หรือเส้นทาง API กับ Backend");
      }

      if (!res.ok) throw new Error(`Download failed with status: ${res.status}`);

      const blob = await res.blob();
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = item.file_name || "downloaded_file";
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);

    } catch (err) {
      console.error("Download Error:", err);
      alert(err.message);
    }
  };

