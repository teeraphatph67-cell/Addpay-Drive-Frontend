  const hasPermission = (action, item = null) => {
    const perm = item ? getItemPermission(item) : shareData?.permission;

    if (!perm) return false;

    // 🔥 แก้ไข: สำหรับ public share อนุญาต view เสมอ
    if (perm.scope === "public") {
      switch (action) {
        case "view":
          return true; // public share ดูได้เสมอ
        case "edit":
          return perm.allow_edit === true || perm.allow_edit === 1;
        case "download":
          return perm.allow_download === true || perm.allow_download === 1;
        default:
          return false;
      }
    }

    // สำหรับ private share ตรวจสอบตามปกติ
    switch (action) {
      case "view":
        return perm.allow_view === true || perm.allow_view === 1;
      case "edit":
        return perm.allow_edit === true || perm.allow_edit === 1;
