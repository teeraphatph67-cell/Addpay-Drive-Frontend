  const getFilenameFromResponse = (res, fallback = "download") => {
    const disposition = res.headers.get("Content-Disposition");
    if (!disposition) return fallback;

    const match =
      disposition.match(/filename\*=UTF-8''(.+)/) ||
      disposition.match(/filename="?([^"]+)"?/);

    return match ? decodeURIComponent(match[1]) : fallback;
  };

  const handleDownload = async (fileItem) => {
    try {
      const file = fileItem?.data;

      const permission =
        fileItem.permission || fileItem.resource_permission || null;

      const permissionId =
        permission?.id ||
        fileItem.resource_permission_id ||
