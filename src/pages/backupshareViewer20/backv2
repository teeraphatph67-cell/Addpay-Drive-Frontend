export default function ShareViewer() {
  const { shareToken, folderId: urlFolderId } = useParams();
  const navigate = useNavigate();
  const location = useLocation();

  const [previewFile, setPreviewFile] = useState(null);
  const [preview, setPreview] = useState(null);
  const [showPreview, setShowPreview] = useState(false);
  const getThumbnailUrl = (file) =>
    `${BASE_URL}api/v1/share/${shareToken}/thumbnail/${file.id}`;
  const canHaveThumbnail = (file) => {
    if (!file?.mime_type) return false;

    return (
      file.mime_type.startsWith("image/") ||
      file.mime_type.includes("pdf") ||
      file.mime_type.startsWith("video/")
    );
  };

  const [state, setState] = useState({
    uploading: false,
    uploadProgress: {},
    sharedData: [],
    currentItems: [],
  });
  const updateState = (payload) => {
    setState((prev) => ({
      ...prev,
      ...payload,
    }));
  };

  const { downloadItems } = useDownloadManager();
  const [isFetchingShare, setIsFetchingShare] = useState(false);
  const [isUploading, setIsUploading] = useState(false);
  const [shareData, setShareData] = useState(null);
  const [error, setError] = useState(null);
  const [copied, setCopied] = useState(false);
  const [currentFolder, setCurrentFolder] = useState(null);
  const [breadcrumbs, setBreadcrumbs] = useState([]);
  const [requiresLogin, setRequiresLogin] = useState(false);
  const [folderLoading, setFolderLoading] = useState(false);
  const [restoringFromStorage, setRestoringFromStorage] = useState(false);
  // State สำหรับการจัดการไฟล์และโฟลเดอร์
  const [showCreateFolderModal, setShowCreateFolderModal] = useState(false);
  const [uploading, setUploading] = useState(false);
  const [creatingFolder, setCreatingFolder] = useState(false);
  const [folderName, setFolderName] = useState("");
  const [uploadProgress, setUploadProgress] = useState({});
  const [uploadError, setUploadError] = useState("");
  const [dragActive, setDragActive] = useState(false);

  const { selectedIds, clearSelection } = useSelection();

  // Refs
  const xhrMapRef = useRef({});
  const fileInputRef = useRef(null);

  // ฟังก์ชันเช็คสถานะล็อกอิน
  const isLoggedIn = () => {
    const token = localStorage.getItem("api_token");
    const user = localStorage.getItem("user");
    return !!(token && user);
  };

  // ✅ ฟังก์ชันสำหรับเปลี่ยน URL เมื่อเข้าถึงโฟลเดอร์ย่อย
  const updateUrlForFolder = (folderId) => {
    const newPath = folderId
      ? `/share/${shareToken}/${folderId}`
      : `/share/${shareToken}`;

    navigate(newPath, { replace: true });
  };

  // ✅ โหลด breadcrumbs และ currentFolder จาก localStorage เมื่อรีเฟรช
  useEffect(() => {
    if (shareToken && !currentFolder && !isFetchingShare) {
      const savedBreadcrumbs = localStorage.getItem(
        `share_${shareToken}_breadcrumbs`,
      );
      const savedCurrentFolder = localStorage.getItem(
        `share_${shareToken}_currentFolder`,
      );
      const savedShareData = localStorage.getItem(`share_${shareToken}_data`);

      if (savedBreadcrumbs && savedCurrentFolder) {
        setRestoringFromStorage(true);
        try {
          const parsedBreadcrumbs = JSON.parse(savedBreadcrumbs);
          const parsedCurrentFolder = JSON.parse(savedCurrentFolder);

          setBreadcrumbs(parsedBreadcrumbs);
          setCurrentFolder(parsedCurrentFolder);

          if (savedShareData) {
            setShareData(JSON.parse(savedShareData));
          }

          // ✅ อัพเดต URL ตามข้อมูลที่โหลดมา
          if (parsedCurrentFolder.id !== shareData?.data?.id) {
            updateUrlForFolder(parsedCurrentFolder.id);
          }

          setTimeout(() => setRestoringFromStorage(false), 500);
        } catch (err) {
          console.error("Error loading saved state:", err);
          setRestoringFromStorage(false);
        }
      }
    }
  }, [shareToken, isFetchingShare]);

  // ✅ บันทึก breadcrumbs และ currentFolder ลง localStorage
  useEffect(() => {
    if (shareToken && currentFolder && breadcrumbs.length > 0) {
      localStorage.setItem(
        `share_${shareToken}_breadcrumbs`,
        JSON.stringify(breadcrumbs),
      );
      localStorage.setItem(
        `share_${shareToken}_currentFolder`,
        JSON.stringify(currentFolder),
      );

      if (shareData) {
        localStorage.setItem(
          `share_${shareToken}_data`,
          JSON.stringify(shareData),
        );
      }
    }
  }, [breadcrumbs, currentFolder, shareData, shareToken]);

  // ✅ ลบข้อมูล localStorage เมื่อออกจากหน้านี้
  useEffect(() => {
    return () => {
      // เก็บข้อมูลไว้ก่อน ไม่ลบตอนออกจาก component
    };
  }, []);

  useEffect(() => {
    if (shareToken) {
      fetchSharedData();
    }
  }, [shareToken]);

  useEffect(() => {
    const fromLogin = location.state?.fromLogin;
    const storedToken = localStorage.getItem("share_redirect_token");

    if (fromLogin && storedToken === shareToken) {
      console.log("Returned from login, refreshing data...");
      localStorage.removeItem("share_redirect_token");
      localStorage.removeItem("share_redirect_path");

      // ล้างข้อมูล localStorage ก่อนโหลดใหม่
      localStorage.removeItem(`share_${shareToken}_breadcrumbs`);
      localStorage.removeItem(`share_${shareToken}_currentFolder`);
      localStorage.removeItem(`share_${shareToken}_data`);

      // รีเฟรชข้อมูล
      fetchSharedData();
    }
  }, [location, shareToken]);

  const fetchSharedData = async () => {
    try {
      setIsFetchingShare(true);
      setRequiresLogin(false);
      setError(null);

      const token = localStorage.getItem("api_token");
      const userEmail = localStorage.getItem("user_email");

      const headers = {
        "Content-Type": "application/json",
      };

      // 🔥 แก้ไข: สำหรับ public share ไม่ต้องส่ง Authorization
      if (token) {
        headers.Authorization = `Bearer ${token}`;
      }

      const res = await fetch(`${API_BASE}/share/${shareToken}`, {
        method: "GET",
        headers,
      });

      const result = await res.json();

      if (!result.success) {
        // 🔥 แก้ไข: สำหรับ public share ให้แสดงข้อความที่เหมาะสม
        if (result.permission?.scope === "public") {
          throw new Error("ลิงก์นี้ไม่ถูกต้องหรือถูกลบแล้ว");
        }

        if (
          res.status === 401 ||
          result.message?.toLowerCase().includes("login") ||
          result.message?.toLowerCase().includes("authenticate") ||
          result.message?.toLowerCase().includes("unauthorized")
        ) {
          if (result.permission?.scope === "private") {
            localStorage.setItem("share_redirect_token", shareToken);
            localStorage.setItem(
              "share_redirect_path",
              window.location.pathname,
            );
            setRequiresLogin(true);
            setError("กรุณาล็อกอินเพื่อเข้าถึงไฟล์นี้");
            return;
          }
          throw new Error("คุณไม่มีสิทธิ์เข้าถึงไฟล์นี้");
        }

        throw new Error(result.message || "ไม่สามารถโหลดข้อมูลได้");
      }

      // 🔐 permission check
      if (result.permission?.scope === "private") {
        const sharedEmail = result.permission.shared_email;

        if (!sharedEmail && !token) {
          setRequiresLogin(true);
          setError("ไฟล์นี้ต้องการการล็อกอิน");
          return;
        }

        if (
          sharedEmail &&
          (!token || userEmail?.toLowerCase() !== sharedEmail.toLowerCase())
        ) {
          setError("คุณไม่ได้รับอนุญาตให้เข้าถึงไฟล์นี้");
          return;
        }
      }

      // 👤 owner
      const ownerName =
        result.data?.owner_name || result.data?.owner?.name || "Anonymous";

      // 🔥 clone share data
      setShareData(
        structuredClone({
          type: result.type,
          permission: {
            ...result.permission,
            // 🔥 แก้ไข: ถ้าเป็น public share ไม่มีวันหมดอายุ
            ...(result.permission?.scope === "public" && {
              expires_at: null, // ไม่มีวันหมดอายุ
              is_permanent: true, // แสดงว่าถาวร
            }),
          },
          owner_name: ownerName,
          data: result.data,
        }),
      );

      // ============================
      // 📁 folder case
      // ============================
      if (result.type === "folder") {
        const folderData = structuredClone(processFolderData(result.data));

        setCurrentFolder(folderData);
        setBreadcrumbs([
          {
            id: folderData.id,
            name: folderData.name || "โฟลเดอร์",
            data: folderData,
          },
        ]);

        localStorage.setItem(
          `share_${shareToken}_breadcrumbs`,
          JSON.stringify([
            {
              id: folderData.id,
              name: folderData.name || "โฟลเดอร์",
              data: folderData,
            },
          ]),
        );

        localStorage.setItem(
          `share_${shareToken}_currentFolder`,
          JSON.stringify(folderData),
        );
      }
    } catch (err) {
      console.error(err);
      setError(err.message || "ไม่สามารถเชื่อมต่อเซิร์ฟเวอร์ได้");
    } finally {
      setIsFetchingShare(false);
    }
  };

  // ฟังก์ชันปรับโครงสร้างข้อมูลโฟลเดอร์ให้สอดคล้อง
  const processFolderData = (folder) => {
    if (!folder) return folder;

    // สร้างสำเนาของข้อมูล
    const processed = { ...folder };

    // กรอง items ออกเป็นไฟล์และโฟลเดอร์
    if (processed.items && Array.isArray(processed.items)) {
      processed.files = processed.items
        .filter((item) => item.type === "file")
        .map((item) => ({
          ...item.data,

          // ✅ สำคัญมาก
          permission_id: item.permission_id,
          permissions: item.permissions,

          file_name: item.data.name,
          file_path: `/storage/${item.data.id}`,
          file_ext: item.data.name?.split(".").pop()?.toLowerCase(),
        }));

      processed.subfolders = processed.items
        .filter((item) => item.type === "folder")
        .map((item) => ({
          ...item.data,

          // (เผื่ออนาคต)
          permission_id: item.permission_id,
          permissions: item.permissions,

          folder_name: item.data.name,
        }));
    }

    return processed;
  };

  // ฟังก์ชันอัพโหลดไฟล์ (รองรับ private + public)
  const handleUploadFiles = async (files) => {
    const permission = shareData?.permission;
    const isPublic = permission?.scope === "public";

    if (!permission?.allow_edit) {
      setUploadError("คุณไม่มีสิทธิ์อัพโหลดไฟล์");
      return;
    }

    const token = localStorage.getItem("api_token");
    if (!isPublic && !token) {
      setUploadError("กรุณาล็อกอินก่อนอัพโหลดไฟล์");
      return;
    }

    const shareToken = permission?.shared_link_token;
    const currentFolderId = currentFolder?.id || null;

    setUploading(true);
    setIsUploading(true);

    const CHUNK_SIZE = 1024 * 1024 * 2;

    for (const file of files) {
      try {
        // ====================
        // 1️⃣ START
        // ====================
        const startFd = new FormData();
        startFd.append("original_name", file.name);
        startFd.append("total_size", file.size);
        if (currentFolderId) {
          startFd.append("folder_id", currentFolderId);
        }

        const startUrl = isPublic
          ? `${API_BASE}/${shareToken}/upload/start`
          : `${API_BASE}/upload/start`;

        const startRes = await fetch(startUrl, {
          method: "POST",
          headers: isPublic ? {} : { Authorization: `Bearer ${token}` },
          body: startFd,
        });

        const startResult = await startRes.json();
        if (!startResult.upload_id) {
          throw new Error(startResult.message || "เริ่มอัพโหลดไม่สำเร็จ");
        }

        const uploadId = startResult.upload_id;
        const fileKey = `${file.name}_${uploadId}`;

        setUploadProgress((p) => ({
          ...p,
          [fileKey]: { percent: 0, uploadId },
        }));

        // =================================================
        // 🌍 PUBLIC → upload ครั้งเดียว
        // =================================================
        if (isPublic) {
          const fd = new FormData();
          fd.append("file", file);
          if (currentFolderId) {
            fd.append("folder_id", currentFolderId);
          }

          const uploadRes = await fetch(
            `${API_BASE}/public/upload/${uploadId}`,
            {
              method: "POST",
              body: fd,
            },
          );

          if (!uploadRes.ok) {
            throw new Error(await uploadRes.text());
          }

          await fetch(
            `${API_BASE}/public/upload/finish/${shareToken}/${uploadId}`,
            { method: "POST" },
          );

          setUploadProgress((p) => ({
            ...p,
            [fileKey]: { percent: 100, uploadId, done: true },
          }));

          setTimeout(() => {
            setUploadProgress((p) => {
              const copy = { ...p };
              delete copy[fileKey];
              return copy;
            });
          }, 1500);

          continue; // ✅ สำคัญ
        }

        // =================================================
        // 🔐 PRIVATE → chunk upload
        // =================================================
        let offset = 0;

        while (offset < file.size) {
          const chunk = file.slice(offset, offset + CHUNK_SIZE);
          const currentOffset = offset;

          offset = await new Promise((resolve, reject) => {
            const xhr = new XMLHttpRequest();
            xhrMapRef.current[fileKey] = xhr;

            xhr.open("POST", `${API_BASE}/upload/chunk`);
            xhr.setRequestHeader("Authorization", `Bearer ${token}`);

            xhr.upload.onprogress = (e) => {
              if (!e.lengthComputable) return;
              const uploaded = currentOffset + e.loaded;
              const percent = Math.min(
                100,
                Math.round((uploaded / file.size) * 100),
              );

              setUploadProgress((p) => ({
                ...p,
                [fileKey]: { percent, uploadId },
              }));
            };

            xhr.onload = () => {
              if (xhr.status >= 200 && xhr.status < 300) {
                const res = JSON.parse(xhr.responseText);
                resolve(res.uploaded_size);
              } else {
                reject(xhr.responseText);
              }
            };

            xhr.onerror = () => reject("network error");

            const fd = new FormData();
            fd.append("upload_id", uploadId);
            fd.append("chunk", chunk);
            fd.append("offset", currentOffset);

            xhr.send(fd);
          });
        }

        const finishFd = new FormData();
        finishFd.append("upload_id", uploadId);

        await fetch(`${API_BASE}/upload/finish`, {
          method: "POST",
          headers: { Authorization: `Bearer ${token}` },
          body: finishFd,
        });

        setUploadProgress((p) => ({
          ...p,
          [fileKey]: { percent: 100, uploadId, done: true },
        }));

        setTimeout(() => {
          setUploadProgress((p) => {
            const copy = { ...p };
            delete copy[fileKey];
            return copy;
          });
        }, 1500);
