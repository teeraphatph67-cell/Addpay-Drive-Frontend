    if (shareData?.permission?.scope === "public") {
      return false; // 🔥 public share ไม่มีวันหมดอายุ
    }

    // 🔐 สำหรับ private share ยังคงตรวจสอบตามปกติ
    if (!shareData?.permission?.expires_at) {
