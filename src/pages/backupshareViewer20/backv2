      if (!permissionId || !file?.id) {
        alert("ไม่พบข้อมูลสำหรับดาวน์โหลด");
        return;
      }

      const scope = permission?.scope || "private";
      const isPublic = scope === "public";

      const token = localStorage.getItem("api_token");

      // ⭐ backend รองรับ folder permission → ต้องส่ง file_id เสมอ
      const downloadUrl = isPublic
        ? `${API_BASE}/public/shared/file/${permissionId}/download?file_id=${file.id}`
        : `${API_BASE}/shared/file/${permissionId}/download?file_id=${file.id}`;

      const headers = {};
      if (!isPublic && token) {
        headers.Authorization = `Bearer ${token}`;
      }

      const res = await fetch(downloadUrl, { headers });

      if (!res.ok) {
        const text = await res.text();
        throw new Error(text || "download failed");
      }

      const blob = await res.blob();
      const url = URL.createObjectURL(blob);

      const a = document.createElement("a");
      a.href = url;
      a.download = file.original_name || file.name;
      document.body.appendChild(a);
      a.click();

      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    } catch (err) {
      console.error("Download error:", err);
      alert("ดาวน์โหลดไม่สำเร็จ");
    }
  };

  const handleDownloadFolder = async (folder) => {
