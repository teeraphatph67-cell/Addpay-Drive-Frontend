                    <FiInfo className="mt-1 text-emerald-500" />
                    <div>
                      <p className="text-gray-400 text-xs">ประเภท</p>
                      <p className="text-gray-700 font-medium">
                        {shareData.type === "folder" ? "โฟลเดอร์" : "ไฟล์"}
                      </p>
                    </div>
                  </div>

                  <div className="flex items-start gap-3 text-sm">
                    <FiUser className="mt-1 text-emerald-500" />
                    <div>
                      <p className="text-gray-400 text-xs">เจ้าของ</p>
                      <p className="text-gray-700 font-medium">
                        {shareData.owner_name}
                      </p>
                    </div>
                  </div>

                  <div className="flex items-start gap-3 text-sm">
                    {shareData.permission?.scope === "public" ? (
                      <FiGlobe className="mt-1 text-green-500" />
                    ) : (
                      <FiLock className="mt-1 text-blue-500" />
                    )}
                    <div>
                      <p className="text-gray-400 text-xs">การเข้าถึง</p>
                      <p
                        className={`font-medium flex items-center gap-1 ${
                          shareData.permission?.scope === "public"
                            ? "text-green-600"
                            : "text-blue-600"
                        }`}
                      >
                        {shareData.permission?.scope === "public" ? (
                          <>
                            <FiGlobe size={12} /> สาธารณะ
                          </>
                        ) : (
                          <>
                            <FiLock size={12} /> ส่วนตัว
                          </>
                        )}
                      </p>
                      {shareData.permission?.scope === "public" && (
                        <p className="text-xs text-green-500 mt-1 flex items-center gap-1">
                          <FiClock size={10} /> ไม่มีวันหมดอายุ
                        </p>
                      )}
                    </div>
                  </div>

                  {shareData.permission?.scope === "private" &&
                    shareData.permission.shared_email && (
                      <div className="flex items-start gap-3 text-sm">
                        <FiMail className="mt-1 text-blue-500" />
                        <div>
                          <p className="text-gray-400 text-xs">แชร์ให้กับ</p>
                          <p className="text-blue-700 font-medium">
                            {shareData.permission.shared_email}
                          </p>
                        </div>
                      </div>
                    )}

                  {shareData.permission?.expires_at &&
                    shareData.permission?.scope !== "public" && (
                      <div className="flex items-start gap-3 text-sm">
                        <FiClock
                          className={`mt-1 ${
                            isLinkExpired()
                              ? "text-red-500"
                              : "text-emerald-500"
                          }`}
                        />
                        <div>
                          <p className="text-gray-400 text-xs">หมดอายุ</p>
                          <p
                            className={`font-medium ${
                              isLinkExpired()
                                ? "text-red-600"
                                : "text-emerald-700"
                            }`}
                          >
                            {new Date(
                              shareData.permission.expires_at,
                            ).toLocaleDateString("th-TH")}
                            <span className="block text-xs font-normal text-gray-500">
                              {new Date(
                                shareData.permission.expires_at,
                              ).toLocaleTimeString("th-TH", {
                                hour: "2-digit",
                                minute: "2-digit",
                              })}
                            </span>
                          </p>
                        </div>
                      </div>
                    )}

                  <div className="pt-3 border-t border-gray-100">
                    <p className="text-xs text-gray-400 mb-2">
                      สิทธิ์การเข้าถึง:
                    </p>
                    <div className="space-y-2">
                      <div className="flex items-center justify-between">
                        <span className="text-sm text-gray-600">ดูข้อมูล</span>
                        <span
                          className={`text-xs px-2 py-1 rounded ${
                            hasPermission("view")
                              ? "bg-emerald-100 text-emerald-700"
                              : "bg-gray-100 text-gray-500"
                          }`}
                        >
                          {hasPermission("view") ? "อนุญาต" : "ไม่อนุญาต"}
                        </span>
                      </div>
                      <div className="flex items-center justify-between">
                        <span className="text-sm text-gray-600">แก้ไข</span>
                        <span
                          className={`text-xs px-2 py-1 rounded ${
                            hasPermission("edit")
                              ? "bg-emerald-100 text-emerald-700"
                              : "bg-gray-100 text-gray-500"
                          }`}
                        >
                          {hasPermission("edit") ? "อนุญาต" : "ไม่อนุญาต"}
                        </span>
                      </div>
                      <div className="flex items-center justify-between">
                        <span className="text-sm text-gray-600">ดาวน์โหลด</span>
                        <span
                          className={`text-xs px-2 py-1 rounded ${
                            hasPermission("download")
                              ? "bg-emerald-100 text-emerald-700"
                              : "bg-gray-100 text-gray-500"
                          }`}
                        >
                          {hasPermission("download") ? "อนุญาต" : "ไม่อนุญาต"}
                        </span>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              {shareData.type === "folder" && currentFolder && (
                <div className="bg-white rounded-2xl border border-gray-200 p-5 shadow-sm">
                  <h3 className="text-sm font-semibold text-emerald-900 uppercase tracking-wider mb-4">
                    สถิติโฟลเดอร์
                  </h3>
                  <div className="space-y-3">
                    <div className="flex items-center justify-between">
                      <span className="text-sm text-gray-600">ไฟล์ทั้งหมด</span>
                      <span className="font-medium text-emerald-700">
                        {(currentFolder.files || []).length}
                      </span>
                    </div>
                    <div className="flex items-center justify-between">
                      <span className="text-sm text-gray-600">
                        โฟลเดอร์ย่อย
                      </span>
                      <span className="font-medium text-emerald-700">
                        {(currentFolder.subfolders || []).length}
                      </span>
                    </div>
                    <div className="flex items-center justify-between">
                      <span className="text-sm text-gray-600">สร้างเมื่อ</span>
                      <span className="text-sm text-gray-500">
                        {new Date(currentFolder.created_at).toLocaleDateString(
                          "th-TH",
                        )}
                      </span>
                    </div>
                  </div>
                </div>
              )}
            </div>
          </div>
        </div>
      </ShareLayout>
      {/* Upload Progress */}
      <UploadProgress progress={uploadProgress} onCancel={cancelUpload} />

      <SelectionActionBar
        onDownload={(selectedItems) => downloadItems(selectedItems)}
      />

      {/* Create Folder Modal */}
      <CreateFolderModal
        isOpen={showCreateFolderModal}
        onClose={() => {
          setShowCreateFolderModal(false);
          setFolderName("");
        }}
        onCreate={handleCreateFolder}
        folderName={folderName}
        setFolderName={setFolderName}
        isFetchingShare={creatingFolder}
      />
      <SharePreviewModal
        show={showPreview}
        file={previewFile}
        onClose={() => {
          setShowPreview(false);
          setPreviewFile(null);
        }}
      />
    </>
  );
}
