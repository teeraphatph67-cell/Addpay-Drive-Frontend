        {!folderLoading && files.length > 0 && (
          <div>
            <h4 className="text-sm font-semibold text-gray-700 mb-2">ไฟล์ ({files.length})</h4>
            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
              {files.map((file) => (
