  };

  const formatFileSize = (sizeMB) => {
    if (!sizeMB && sizeMB !== 0) return "Unknown";
    if (sizeMB < 1) return `${(sizeMB * 1024).toFixed(0)} KB`;
    return `${sizeMB.toFixed(2)} MB`;
  };

  const hasPermission = (action, item = null) => {
    const perm = item
      ? getItemPermission(item)
      : shareData?.permission;

    if (!perm) return false;

    switch (action) {
      case "view":
        return perm.allow_view === true || perm.allow_view === 1;
      case "edit":
        return perm.allow_edit === true || perm.allow_edit === 1;
      case "download":
        return perm.allow_download === true || perm.allow_download === 1;
      default:
        return false;
    }
  };

  const isLinkExpired = () => {
    if (!shareData?.permission?.expires_at) return false;
    return new Date(shareData.permission.expires_at) < new Date();
  };

  const openPreview = async (file) => {
    try {
      const token = localStorage.getItem("api_token");

      const res = await fetch(
        `${API_BASE}/preview/${shareToken}/${file.id}`,
        {
          headers: token
            ? { Authorization: `Bearer ${token}` }
            : {},
        }
      );

      if (!res.ok) {
        alert("ไม่สามารถโหลดไฟล์ได้");
        return;
      }

      const blob = await res.blob();
      const url = URL.createObjectURL(blob);

      let type = "other";
      if (file.mime_type?.startsWith("image/")) type = "image";
      else if (file.mime_type?.includes("pdf")) type = "pdf";
      else if (file.mime_type?.startsWith("video/")) type = "video";
      else if (file.mime_type?.startsWith("audio/")) type = "audio";

      setPreview({
        url,
        type,
        file_name: file.file_name,
      });
    } catch (e) {
      console.error(e);
      alert("เกิดข้อผิดพลาด");
    }
  };




  // ShareViewer.js - แก้ไขฟังก์ชัน fetchFolderContent
  const fetchFolderContent = async (folderId) => {
    try {
      setFolderLoading(true);

      const token = localStorage.getItem("api_token");
      const headers = {
        "Content-Type": "application/json",
        ...(token && { Authorization: `Bearer ${token}` }),
      };

      console.log("Fetching folder content:", folderId);

      const tryFetch = async (url) => {
        const res = await fetch(url, { method: "GET", headers });
        if (!res.ok) return null;
        return await res.json();
      };

      // 🔹 ลองทุก endpoint ตามลำดับ
      const responses = [
        `${API_BASE}/share/${shareToken}?folder_id=${folderId ?? ""}`,
        `${API_BASE}/share/${shareToken}/folder/${folderId}`,
        `${API_BASE}/share/${shareToken}`,
      ];

      let result = null;
      for (const url of responses) {
        const data = await tryFetch(url);
        if (data?.success) {
          result = data;
          break;
        }
      }

      if (!result?.data) return null;

      let folderData = null;

      // 🔹 case: API ส่ง folder ตรงมา
      if (result.data.id === folderId || folderId === null) {
        folderData = result.data;
      }

      // 🔹 case: ค้นจาก items
      if (!folderData && Array.isArray(result.data.items)) {
        const found = result.data.items.find(
          (item) => item.type === "folder" && item.data?.id === folderId
        );
        if (found) folderData = found.data;
      }

      if (!folderData) return null;

      // 🔥 สำคัญที่สุด: clone object ทุกครั้ง
      const processed = processFolderData(folderData);
      return structuredClone(processed);

    } catch (err) {
      console.error("Error fetching folder content:", err);
      return null;
    } finally {
      setFolderLoading(false);
    }
  };


  // ✅ รีเฟรชเฉพาะโฟลเดอร์ปัจจุบันโดยไม่ต้องกลับไปหน้าแรก
  // ShareViewer.js - แก้ไขฟังก์ชัน refreshCurrentFolder
  const refreshCurrentFolder = async () => {
    if (!currentFolder?.id || !shareToken) return;

    try {
      setFolderLoading(true);
      const token = localStorage.getItem("api_token");
      const headers = {
        "Content-Type": "application/json",
      };

      if (token) {
        headers["Authorization"] = `Bearer ${token}`;
      }

      // ✅ วิธีที่ 1: ลองโหลดข้อมูลโฟลเดอร์หลักใหม่
      const res = await fetch(`${API_BASE}/share/${shareToken}`, {
        method: "GET",
        headers: headers,
      });

      if (res.ok) {
        const result = await res.json();
        if (result.success && result.data) {

          // ✅ ฟังก์ชันค้นหาโฟลเดอร์ที่ต้องการในโครงสร้าง tree
          const findFolderInTree = (items, targetId) => {
            if (!items || !Array.isArray(items)) return null;

            for (const item of items) {
              if (item.type === 'folder' && item.data?.id === targetId) {
                return item.data;
              }

              // ถ้า item นี้มี items อยู่ข้างใน (โฟลเดอร์ย่อย)
              if (item.data?.items) {
                const found = findFolderInTree(item.data.items, targetId);
                if (found) return found;
              }
            }
            return null;
          };

          let folderToUpdate = null;

          // ✅ ตรวจสอบว่าเป็นโฟลเดอร์ root หรือไม่
          if (result.data.id === currentFolder.id) {
            folderToUpdate = result.data;
          } else {
            // ✅ ค้นหาโฟลเดอร์ในโครงสร้าง tree
            folderToUpdate = findFolderInTree(result.data.items, currentFolder.id);
          }

          if (folderToUpdate) {
            const updatedFolder = processFolderData(folderToUpdate);
            setCurrentFolder(updatedFolder);

            // ✅ อัพเดต breadcrumb เฉพาะตำแหน่งปัจจุบัน
            setBreadcrumbs(prev =>
              prev.map((crumb, index) =>
                index === prev.length - 1
                  ? { ...crumb, data: updatedFolder }
                  : crumb
              )
            );

            // ✅ บันทึกข้อมูลใหม่ลง localStorage
            localStorage.setItem(`share_${shareToken}_breadcrumbs`, JSON.stringify(breadcrumbs));
            localStorage.setItem(`share_${shareToken}_currentFolder`, JSON.stringify(updatedFolder));

            console.log("Current folder refreshed successfully");
          } else {
            console.warn("Folder not found in response, keeping current data");
          }
        }
      } else {
        console.error("Failed to refresh folder:", res.status);
      }
    } catch (err) {
      console.error("Error refreshing current folder:", err);
    } finally {
      setFolderLoading(false);
    }
  };

  // ShareViewer.js - แก้ไขฟังก์ชัน handleFolderClick
  const handleFolderClick = async (folder) => {
    if (shareData.permission?.scope === "private") {
      if (!hasPermission('view')) {
        alert("คุณไม่มีสิทธิ์เข้าถึงโฟลเดอร์นี้");
        return;
      }

      if (isLinkExpired()) {
        alert("ลิงก์นี้หมดอายุแล้ว");
        return;
      }
    }

    try {
      // ✅ 1. ตรวจสอบว่ามีข้อมูล items อยู่แล้วใน currentFolder หรือไม่
      let folderContent = null;

      // ฟังก์ชันค้นหาโฟลเดอร์ในโครงสร้างปัจจุบัน
      const findFolderInCurrentData = () => {
        if (!currentFolder?.items && !currentFolder?.subfolders) return null;

        const items = currentFolder.items || currentFolder.subfolders;
        const target = items.find(item =>
          item.id === folder.id ||
          item.data?.id === folder.id ||
          (item.type === 'folder' && item.data?.id === folder.id)
        );

        return target ? target.data || target : null;
      };

      // ✅ 2. ลองหาจากข้อมูลปัจจุบันก่อน
      const foundInCurrent = findFolderInCurrentData();
      if (foundInCurrent) {
        folderContent = foundInCurrent;
      } else {
        // ✅ 3. ถ้าไม่พบ ให้ลองดึงจาก API
        folderContent = await fetchFolderContent(folder.id);
      }

      if (folderContent) {
        // ✅ 4. ประมวลผลข้อมูลโฟลเดอร์
        const processedFolder = processFolderData(folderContent);
        const newBreadcrumbs = [...breadcrumbs, {
          id: processedFolder.id,
          name: processedFolder.name || processedFolder.folder_name,
          data: processedFolder
        }];
        setBreadcrumbs(newBreadcrumbs);
        setCurrentFolder(processedFolder);

        // ✅ 5. บันทึกข้อมูลใหม่ลง localStorage
        localStorage.setItem(`share_${shareToken}_breadcrumbs`, JSON.stringify(newBreadcrumbs));
        localStorage.setItem(`share_${shareToken}_currentFolder`, JSON.stringify(processedFolder));

        // ✅ 6. อัพเดต URL (ถ้าต้องการ)
        updateUrlForFolder(processedFolder.id);
      } else {
        // ✅ 7. ใช้ข้อมูลจาก folder ที่ส่งเข้ามาโดยตรง (fallback)
        const processedFolder = processFolderData(folder);
        const newBreadcrumbs = [...breadcrumbs, {
          id: processedFolder.id,
          name: processedFolder.name || processedFolder.folder_name,
          data: processedFolder
        }];
        setBreadcrumbs(newBreadcrumbs);
        setCurrentFolder(processedFolder);

        // ✅ 8. บันทึกข้อมูลใหม่ลง localStorage
        localStorage.setItem(`share_${shareToken}_breadcrumbs`, JSON.stringify(newBreadcrumbs));
        localStorage.setItem(`share_${shareToken}_currentFolder`, JSON.stringify(processedFolder));

        // ✅ 9. อัพเดต URL (ถ้าต้องการ)
        updateUrlForFolder(processedFolder.id);

        console.log("Using provided folder data (no additional content available)");
      }
    } catch (err) {
      console.error("Error handling folder click:", err);
      alert("ไม่สามารถเข้าถึงโฟลเดอร์ได้: " + err.message);
    }
  };

  const handleGoBack = () => {
    if (breadcrumbs.length > 1) {
      const newBreadcrumbs = breadcrumbs.slice(0, -1);
      const prevFolder = newBreadcrumbs[newBreadcrumbs.length - 1];

      setBreadcrumbs(newBreadcrumbs);
      setCurrentFolder(prevFolder.data);

      // ✅ บันทึกข้อมูลใหม่ลง localStorage
      localStorage.setItem(`share_${shareToken}_breadcrumbs`, JSON.stringify(newBreadcrumbs));
      localStorage.setItem(`share_${shareToken}_currentFolder`, JSON.stringify(prevFolder.data));

      // ✅ อัพเดต URL
      updateUrlForFolder(prevFolder.id);
    } else {
      // กลับไปโฟลเดอร์ root
      const rootFolder = breadcrumbs[0];
      setBreadcrumbs([rootFolder]);
      setCurrentFolder(rootFolder.data);

      // ✅ บันทึกข้อมูลใหม่ลง localStorage
      localStorage.setItem(`share_${shareToken}_breadcrumbs`, JSON.stringify([rootFolder]));
      localStorage.setItem(`share_${shareToken}_currentFolder`, JSON.stringify(rootFolder.data));

      // ✅ อัพเดต URL (ลบ folderId ออก)
      updateUrlForFolder(null);
    }
  };

  const handleBreadcrumbClick = async (index) => {
    // คลิกตำแหน่งปัจจุบัน ไม่ต้องทำอะไร
    if (index === breadcrumbs.length - 1) return;

    const breadcrumb = breadcrumbs[index];

    try {
      let folderData = null;

      // 🔹 root folder
      if (index === 0) {
        folderData = await fetchFolderContent(null); // root
        updateUrlForFolder(null);
      } else {
        folderData = await fetchFolderContent(breadcrumb.id);
        updateUrlForFolder(breadcrumb.id);
      }

      if (!folderData) return;

      // 🔹 สร้าง breadcrumb ใหม่ (ตัดอันหลังทิ้ง)
      const newBreadcrumbs = breadcrumbs
        .slice(0, index + 1)
        .map((bc, i) =>
          i === index ? { ...bc, data: folderData } : bc
        );

      // 🔹 update state
      setBreadcrumbs(newBreadcrumbs);
      setCurrentFolder(folderData);

      // 🔹 sync localStorage
      localStorage.setItem(
        `share_${shareToken}_breadcrumbs`,
        JSON.stringify(newBreadcrumbs)
      );
      localStorage.setItem(
        `share_${shareToken}_currentFolder`,
        JSON.stringify(folderData)
      );
    } catch (err) {
      console.error('Breadcrumb navigation failed:', err);
    }
  };


  const getItemPermission = (item) => {
    return item.permissions || shareData?.permission || null;
  };

  const handleDownload = async (item) => {
    const pId = item.permission_id || item.id || shareData?.permission?.id;

    if (!pId) {
      alert("ไม่พบ ID สำหรับดาวน์โหลด");
      return;
    }

    try {
      const token = localStorage.getItem("api_token");

      const downloadUrl = `${API_BASE}/shared/file/${pId}/download`;
      console.log("Downloading from:", downloadUrl);

      const res = await fetch(downloadUrl, {
        method: "GET",
        headers: {
          "Authorization": `Bearer ${token}`,
          "Accept": "application/json",
        },
      });

      if (res.status === 404) {
        throw new Error("ไม่พบไฟล์ที่ต้องการดาวน์โหลด (404) กรุณาตรวจสอบ ID หรือเส้นทาง API กับ Backend");
      }

      if (!res.ok) throw new Error(`Download failed with status: ${res.status}`);

      const blob = await res.blob();
      const url = URL.createObjectURL(blob);
      const a = document.createElement("a");
      a.href = url;
      a.download = item.file_name || "downloaded_file";
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);

    } catch (err) {
      console.error("Download Error:", err);
      alert(err.message);
    }
  };

  // Action Buttons Component
  const ActionButtons = () => {
    // แสดงปุ่มเฉพาะถ้าเป็นโฟลเดอร์และมีสิทธิ์ edit
    if (!shareData || shareData.type !== 'folder' || !hasPermission('edit')) {
      return null;
    }

    return (
      <div className="mb-4">
        <div className="flex items-center gap-2">
          {/* Upload Button */}
          <button
            onClick={() => fileInputRef.current?.click()}
            className="flex items-center gap-2 bg-emerald-600 text-white px-4 py-2 rounded-lg hover:bg-emerald-700 shadow-sm transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
            disabled={uploading}
          >
            <FiUpload size={16} />
            <span>{uploading ? "กำลังอัพโหลด..." : "อัพโหลดไฟล์"}</span>
          </button>

          {/* Create Folder Button */}
          <button
            onClick={() => setShowCreateFolderModal(true)}
            className="flex items-center gap-2 bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 shadow-sm transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
            disabled={creatingFolder}
          >
            <FiPlus size={16} />
            <span>{creatingFolder ? "กำลังสร้าง..." : "สร้างโฟลเดอร์"}</span>
          </button>

          {/* Hidden File Input */}
          <input
            type="file"
            ref={fileInputRef}
            multiple
            className="hidden"
            onChange={handleFileSelect}
          />
        </div>

        {/* Drag & Drop Hint */}
        <p className="text-xs text-gray-500 mt-2">
          ลากไฟล์มาวางในพื้นที่นี้เพื่ออัพโหลดได้ทันที
        </p>
      </div>
    );
  };
  const renderFilePreview = (file) => {
    return (
      <div className="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">

        {/* HEADER */}
        <div className="p-4 border-b bg-gray-50 flex justify-between">
          <span className="font-medium">{file.file_name}</span>

          {hasPermission("view") && (
            <button
              onClick={() => openPreview(file)}
              className="px-3 py-1.5 bg-emerald-600 text-white rounded-lg"
            >
              ดูไฟล์
            </button>
          )}
        </div>
      </div>
    );
  };

  const renderFolderContent = (folder) => {
    if (!folder) return null;

    // ดึงข้อมูลไฟล์และโฟลเดอร์ย่อยจาก field ต่างๆ
    const files = folder.files || [];
    const subfolders = folder.subfolders || [];

    return (
      <div
        className="space-y-6"
        onDragEnter={hasPermission("edit") ? handleDrag : undefined}
        onDragOver={hasPermission("edit") ? handleDrag : undefined}
        onDragLeave={hasPermission("edit") ? handleDrag : undefined}
        onDrop={hasPermission("edit") ? handleDrop : undefined}

      >
        <div className="flex items-center gap-2 text-sm text-gray-600 mb-4">
          <button
            onClick={handleGoBack}
            className={`p-1 hover:bg-gray-100 rounded ${breadcrumbs.length <= 1 ? 'opacity-50 cursor-not-allowed' : ''}`}
            disabled={breadcrumbs.length <= 1}
          >
            <FiArrowLeft size={16} />
          </button>
          {breadcrumbs.map((crumb, index) => (
            <div key={crumb.id} className="flex items-center">
              {index > 0 && <FiChevronRight size={14} className="mx-2" />}
              <button
                onClick={() => handleBreadcrumbClick(index)}
                className={`px-2 py-1 rounded hover:bg-gray-100 ${index === breadcrumbs.length - 1 ? 'font-semibold text-gray-800' : ''
                  }`}
              >
                {crumb.name}
              </button>
            </div>
          ))}
        </div>

        {/* Action Buttons */}
        <ActionButtons />

        {/* Error Message */}
        {uploadError && (
          <div className="bg-red-50 border border-red-200 rounded-lg p-3 mb-4">
            <div className="flex items-center gap-2 text-red-700">
              <FiAlertCircle size={16} />
              <span className="text-sm">{uploadError}</span>
              <button
                onClick={() => setUploadError("")}
                className="ml-auto text-red-500 hover:text-red-700"
              >
                <FiX size={16} />
              </button>
            </div>
          </div>
        )}

        {/* Drag & Drop Zone */}
        {dragActive && hasPermission('edit') && (
          <div className="fixed inset-0 bg-black/10 flex items-center justify-center z-40 pointer-events-none">
            <div className="bg-white/90 backdrop-blur-sm rounded-2xl p-8 border-2 border-dashed border-emerald-500">
              <div className="text-center">
                <FiUpload size={48} className="mx-auto mb-4 text-sky-" />
                <p className="text-lg font-medium text-emerald-700">วางไฟล์ที่นี่เพื่ออัพโหลด</p>
              </div>
            </div>
          </div>
        )}

        {folderLoading && (
          <div className="text-center py-8">
            <div className="w-12 h-12 border-4 border-sky-100 border-t-sky-500 rounded-full animate-spin mx-auto mb-4"></div>
            <p className="text-emerald-700">กำลังโหลดข้อมูลโฟลเดอร์...</p>
          </div>
        )}

        {!folderLoading && subfolders.length > 0 && (
          <div>
            <h4 className="text-sm font-semibold text-gray-700 mb-2">โฟลเดอร์ ({subfolders.length})</h4>
            <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
              {subfolders.map((subfolder) => (
                <button
                  key={subfolder.id}
                  onClick={() => handleFolderClick(subfolder)}
                  disabled={!hasPermission('view') || isLinkExpired()}
                  className={`p-3 bg-white border rounded-lg flex items-center gap-3 text-left transition-all ${hasPermission('view') && !isLinkExpired()
                    ? 'border-gray-200 hover:border-sky-300 hover:shadow-sm cursor-pointer group'
                    : 'border-gray-100 opacity-50 cursor-not-allowed'
                    }`}
                >
                  <TbFolderFilled className="text-yellow-400 flex-shrink-0" size={24} />
                  <div className="flex-1 min-w-0">
