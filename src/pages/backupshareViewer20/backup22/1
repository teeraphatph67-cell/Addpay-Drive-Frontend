// Upload Progress Component
const UploadProgress = ({ progress, onCancel }) => {
  if (Object.keys(progress).length === 0) return null;

  return (
    <div className="fixed bottom-4 right-4 z-50 max-w-sm w-full">
      {Object.entries(progress).map(([fileName, data]) => (
        <div
          key={fileName}
          className="bg-white rounded-xl shadow-lg border border-gray-200 p-3 mb-2"
        >
          <div className="flex items-center justify-between mb-1">
            <span className="text-sm font-medium truncate max-w-[200px]">
              {fileName}
            </span>
            <button
              onClick={() => onCancel(fileName)}
              className="text-gray-400 hover:text-red-500 text-xs"
            >
              ยกเลิก
            </button>
          </div>
          <div className="w-full bg-gray-200 rounded-full h-2">
            <div
              className="bg-emerald-500 h-2 rounded-full transition-all duration-300"
              style={{ width: `${data.percent || 0}%` }}
            />
          </div>
          <div className="text-xs text-gray-500 mt-1 text-right">
            {data.percent || 0}%
          </div>
        </div>
      ))}
    </div>
  );
};





