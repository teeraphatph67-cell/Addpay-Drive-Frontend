  const [folderName, setFolderName] = useState("");
  const [uploadProgress, setUploadProgress] = useState({});
  const [uploadError, setUploadError] = useState("");
  const [dragActive, setDragActive] = useState(false);

  // Refs
  const xhrMapRef = useRef({});
  const fileInputRef = useRef(null);

  // ฟังก์ชันเช็คสถานะล็อกอิน
  const isLoggedIn = () => {
    const token = localStorage.getItem("api_token");
    const user = localStorage.getItem("user");
    return !!(token && user);
  };

  // ✅ ฟังก์ชันสำหรับเปลี่ยน URL เมื่อเข้าถึงโฟลเดอร์ย่อย
  const updateUrlForFolder = (folderId) => {
    const newPath = folderId
      ? `/share/${shareToken}/${folderId}`
      : `/share/${shareToken}`;

    navigate(newPath, { replace: true });
  };

  // ✅ โหลด breadcrumbs และ currentFolder จาก localStorage เมื่อรีเฟรช
  useEffect(() => {
    if (shareToken && !currentFolder && !isFetchingShare) {
      const savedBreadcrumbs = localStorage.getItem(`share_${shareToken}_breadcrumbs`);
      const savedCurrentFolder = localStorage.getItem(`share_${shareToken}_currentFolder`);
      const savedShareData = localStorage.getItem(`share_${shareToken}_data`);

      if (savedBreadcrumbs && savedCurrentFolder) {
        setRestoringFromStorage(true);
        try {
          const parsedBreadcrumbs = JSON.parse(savedBreadcrumbs);
          const parsedCurrentFolder = JSON.parse(savedCurrentFolder);

          setBreadcrumbs(parsedBreadcrumbs);
          setCurrentFolder(parsedCurrentFolder);

          if (savedShareData) {
            setShareData(JSON.parse(savedShareData));
          }

          // ✅ อัพเดต URL ตามข้อมูลที่โหลดมา
          if (parsedCurrentFolder.id !== shareData?.data?.id) {
            updateUrlForFolder(parsedCurrentFolder.id);
          }

          setTimeout(() => setRestoringFromStorage(false), 500);
        } catch (err) {
          console.error("Error loading saved state:", err);
          setRestoringFromStorage(false);
        }
      }
    }
  }, [shareToken, isFetchingShare]);

  // ✅ บันทึก breadcrumbs และ currentFolder ลง localStorage
  useEffect(() => {
    if (shareToken && currentFolder && breadcrumbs.length > 0) {
      localStorage.setItem(`share_${shareToken}_breadcrumbs`, JSON.stringify(breadcrumbs));
      localStorage.setItem(`share_${shareToken}_currentFolder`, JSON.stringify(currentFolder));

      if (shareData) {
        localStorage.setItem(`share_${shareToken}_data`, JSON.stringify(shareData));
      }
    }
  }, [breadcrumbs, currentFolder, shareData, shareToken]);

  // ✅ ลบข้อมูล localStorage เมื่อออกจากหน้านี้
  useEffect(() => {
    return () => {
      // เก็บข้อมูลไว้ก่อน ไม่ลบตอนออกจาก component
    };
  }, []);

  useEffect(() => {
    if (shareToken) {
      fetchSharedData();
    }
  }, [shareToken]);

  useEffect(() => {
